# Yieldwise — local dev environment template.
# Copy to .env (gitignored) and edit.

# === Postgres connection ===
# Point at your local Postgres + PostGIS instance.
# Postgres.app users: postgresql://localhost:5432/yieldwise
POSTGRES_DSN=postgresql://localhost:5432/yieldwise

# === App ===
SESSION_SECRET=dev-only-please-replace-in-production

# Initial admin seed (created on first boot, idempotent).
ATLAS_ADMIN_USERNAME=admin
ATLAS_ADMIN_PASSWORD=changeme-after-first-login

# === Map keys (the map won't render without these) ===

# Get a free personal key for local dev:
# https://lbs.amap.com/api/javascript-api-v2/prerequisites
AMAP_API_KEY=
AMAP_SECURITY_JSCODE=
# AMAP_WEB_SERVICE_KEY is only needed if you run the geocoding helper jobs.
AMAP_WEB_SERVICE_KEY=

# === Optional ===

# Reference catalog override — point the app at a staged reference run instead
# of the database (used during dev when the DB hasn't been seeded yet).
# ATLAS_REFERENCE_CATALOG_FILE=tmp/reference-runs/shanghai-citywide-reference/reference_catalog.json
